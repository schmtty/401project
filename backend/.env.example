# Database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ab2
PGSSL=false

# Server port (optional, defaults to 3001)
PORT=3001

# Google AI (Gemini) API key for RizzBot - get one at https://aistudio.google.com/apikey
# If not set, RizzBot falls back to rule-based suggestions
GOOGLE_AI_API_KEY=
